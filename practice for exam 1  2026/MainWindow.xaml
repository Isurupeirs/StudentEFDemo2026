<Window x:Class="practice_for_exam_1__2026.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:practice_for_exam_1__2026"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0" 
                   Text="Student Management System"
                   FontSize="20" 
                   FontWeight="Bold"
                   HorizontalAlignment="Center"
                   Margin="10"/>

        <!-- Buttons Panel -->
        <WrapPanel Grid.Row="1" 
                   HorizontalAlignment="Center" 
                   Margin="10">

            <Button Content="Insert Students"
                    Click="InsertStudents_Click"
                    Width="120" Height="35" Margin="5"/>

            <Button Content="Load Students"
                    Click="LoadStudents_Click"
                    Width="120" Height="35" Margin="5"/>

            <Button Content="Search Emma"
                    Click="SearchEmma_Click"
                    Width="120" Height="35" Margin="5"/>

            <Button Content="Sort By Name"
                    Click="SortByName_Click"
                    Width="120" Height="35" Margin="5"/>

            <Button Content="Count Students"
                    Click="CountStudents_Click"
                    Width="120" Height="35" Margin="5"/>

            <Button Content="First Student"
                    Click="FirstStudent_Click"
                    Width="120" Height="35" Margin="5"/>

            <Button Content="Update Emma"
                    Click="UpdateEmma_Click"
                    Width="120" Height="35" Margin="5"/>

            <Button Content="Delete Emily"
                    Click="DeleteEmily_Click"
                    Width="120" Height="35" Margin="5"/>
            <Button Content="Clear Database"
        Click="ClearDatabase_Click"
        Width="120" Height="35" Margin="5"/>
        </WrapPanel>

        <!-- DataGrid to show students -->
        <DataGrid Grid.Row="2"
                  x:Name="StudentDataGrid"
                  Margin="10"
                  AutoGenerateColumns="True"
                  IsReadOnly="True"/>

    </Grid>
</Window>
